@model Terrains_Treasures.ViewModels.ProductDetailsViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Product Details";
}
<h1> Product Details</h1>
<div class="row">
    <div class="col-md-6 bg-dark">
        <!-- Carousel -->
        <div id="carouselExample" class="carousel slide" >
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/Images/@Model.Product.ProductId/@Model.Product.ImageName" class="d-block w-100" style="height:500px; object-fit:contain;" />
                </div>
                @foreach(var image in Model.Images)
                {
                    <div class="carousel-item">
                        <img src="~/Images/@image.ProductId/@image.ImageName" class="d-block w-100" style="height:500px; object-fit:contain;" />
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
    <!-- Product Details -->
    <div class="col-md-6">
        <h2>@Model.Product.Name</h2>
        <p>@Model.Product.Description</p>
        <h4 class="text-primary">$@Model.Product.Price</h4>
        <form asp-controller="Cart" asp-action="Add" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="productId" value="@Model.Product.ProductId" />

            <label asp-for="SelectedQuantity" class="col-form-label">Quantity</label>
            <select asp-for="SelectedQuantity" class="form-select form-select-sm">
               @for(int i = 1; i <= Model.QuantityInStock; i++)
               {
                   <option value="@i">@i</option>
               }
)
            </select>
            <br/>
            <button class="btn btn-success mt-2" type="submit">Add to Cart</button>
        </form>
        
    </div>
</div>
