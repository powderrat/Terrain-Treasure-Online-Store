
@{
    ViewData["Title"] = "Update Products";
}

<div class="accordion" id="ProductsTableAccordion">
    <!--Product table -->
    <div class="accordion-item">
        <h2 class="accordion-header" id="ProductsTableHeading">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#ProductsTableCollapse" aria-expanded="true" aria-controls="ProductsTableCollapse">
                Products Table
            </button>
        </h2>
        <div id="ProductsTableCollapse" class="accordion-collapse collapse show" aria-labelledby="ProductsTableHeading" data-bs-parent="#ProductsTableAccordion">
            <div class="accordion-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Example product row -->
                        <tr>
                            <td>Forest Tiles</td>
                            <td>High-quality forest-themed tiles for your gaming needs.</td>
                            <td>$55.00</td>
                            <td><button class="btn btn-primary">Edit</button></td>
                        </tr>
                        
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!--Add new item form-->

    <div class="accordion-item">
        <h2 class="accordion-header" id="AddProductHeading">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#AddProductCollapse" aria-expanded="true" aria-controls="AddProductCollapse">
                Add New Product
            </button>
        </h2>
        <div id="AddProductCollapse" class="accordion-collapse collapse show" aria-labelledby="AddProductHeading" data-bs-parent="#ProductsTableAccordion">
            <div class="accordion-body">
                <form asp-controller="Admin" asp-action="AddProduct" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">

                      
                        <div class="col-md-6">
                            <label for="Name" class="form-label fw-semibold">Product Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="Name" name="Name"
                                   placeholder="e.g. Forest Tiles" required />
                        </div>

                        
                        <div class="col-md-6">
                            <label for="Price" class="form-label fw-semibold">Price <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" id="Price" name="Price"
                                       placeholder="0.00" step="0.01" min="0" required />
                            </div>
                        </div>

                        
                        <div class="col-12">
                            <label for="Description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="Description" name="Description"
                                      rows="3" placeholder="Describe the product..." required></textarea>
                        </div>

                        
                        <div class="col-md-6">
                            <label for="MainImage" class="form-label fw-semibold">Main Image <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" id="MainImage" name="MainImage"
                                   accept="image/*" required />
                            <div class="form-text">This will be the primary product image shown on cards.</div>
                        </div>

                       
                        <div class="col-md-6">
                            <label for="AdditionalImages" class="form-label fw-semibold">Additional Images</label>
                            <input type="file" class="form-control" id="AdditionalImages" name="AdditionalImages"
                                   accept="image/*" multiple />
                            <div class="form-text">Optional. These appear in the product detail carousel.</div>
                        </div>

                        
                        <div class="col-12">
                            <div id="imagePreviewContainer" class="d-flex flex-wrap gap-2 mt-1"></div>
                        </div>

                        
                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-success me-2">
                                <i class="bi bi-plus-circle me-1"></i> Add Product
                            </button>
                            <button type="reset" class="btn btn-outline-secondary" id="resetBtn">
                                Clear
                            </button>
                        </div>

                    </div>
                </form>

             </div>       
    </div>
</div>