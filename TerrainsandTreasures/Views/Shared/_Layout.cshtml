<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Terrains_Treasures</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Terrains_Treasures.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header>
        <div class="position-relative d-flex align-items-center mb-3 py-2 bg-body">
          
            <!--Logo-->
            <div class="position-absolute top-50 start-50 translate-middle">
                <a asp-controller="Home"
                   asp-action="Index"> <img src="~/Images/Banner.png" class="img-fluid" alt="Responsive Image of Banner" /> </a>
            </div>

            <!--Icons-->
            <div class="ms-auto d-flex gap-1">
                <div class="p-2 me-3 "><a asp-controller="Account" asp-action="Dashboard" class="link-warning fs-2"><i class="bi bi-person "></i></a></div>
                <div class="p-2 me-3 "><a asp-controller="Cart" asp-action="index" class="link-warning  fs-2 "><i class="bi bi-cart"> </i></a></div>
            </div>
            
        </div>

        
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-3" style="background-color: #f2f2f2;">
        <div class="container text-center">
            <a asp-controller="Home" asp-action="About" class="text-muted me-3">About Us</a>
            <a asp-controller="Home" asp-action="Contact" class="text-muted">Contact Us</a>
            <div><img src="https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg"
                 alt="Stripe" style="height:20px; filter:invert(1);" />
            <small class="ms-2">Payments powered by Stripe</small></div>
            
            <p class="text-muted mb-0 mt-2">&copy; Terrains & Treasures 2026</p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
